---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 3em 0 2em;
        border-bottom: 1px solid var(--border);
        margin-bottom: 3em;
      }
      .hero h1 { font-size: 2.2em; margin: 0 0 0.3em; }
      .hero p {
        color: var(--text-secondary);
        font-size: 1.1em;
        margin: 0;
        max-width: 560px;
      }
      .posts-section h2 {
        font-size: 1.2em;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0 0 1.5em;
      }
      .post-list { list-style: none; padding: 0; margin: 0; }
      .post-item {
        padding: 1.2em 0;
        border-bottom: 1px solid var(--border);
      }
      .post-item:last-child { border-bottom: none; }
      .post-item a { text-decoration: none; display: block; }
      .post-item h3 {
        margin: 0 0 0.3em;
        font-size: 1.25em;
        color: var(--text-bright);
        transition: color 0.15s ease;
      }
      .post-item a:hover h3 { color: var(--accent); }
      .post-item .desc {
        color: var(--text-secondary);
        font-size: 0.95em;
        margin: 0 0 0.5em;
      }
      .post-item .meta {
        color: var(--text-secondary);
        font-size: 0.85em;
        display: flex;
        gap: 1em;
        align-items: center;
      }
      .tag-sm {
        background: var(--bg-elevated);
        color: var(--accent);
        padding: 0.1em 0.5em;
        border-radius: 10px;
        font-size: 0.8em;
        border: 1px solid var(--border);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>AI Security Distilled</h1>
        <p>{SITE_DESCRIPTION}</p>
      </section>

      <section class="posts-section">
        <h2>Latest Posts</h2>
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`${base}/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p class="desc">{post.data.description}</p>
                <div class="meta">
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag-sm">{tag}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
